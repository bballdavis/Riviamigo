# Riviamigo standard production configuration
# Copy to .env in the repository root and replace each CHANGE_ME value.
# Optional settings are listed in compose/.env.full.example and documented at
# https://riviamigo.com/docs/reference/environment-variables/

POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
ALLOWED_ORIGINS=https://riviamigo.example.net
