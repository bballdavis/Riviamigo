# Riviamigo complete environment reference
#
# Most self-hosters should copy compose/.env.example to .env and change only
# those required values. This file is the reference for production Compose,
# direct API runs, and local development overrides. Keep real values in .env,
# .env.local, or your deployment secret manager; never commit them.

# Required by compose/docker-compose.yml.
POSTGRES_USER=riviamigo
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
DATABASE_URL=postgresql://riviamigo:CHANGE_ME_DATABASE_PASSWORD@timescaledb:5432/riviamigo
ALLOWED_ORIGINS=https://riviamigo.example.net
JWT_SECRET=CHANGE_ME_RSA_PRIVATE_KEY
JWT_PUBLIC_KEY=CHANGE_ME_RSA_PUBLIC_KEY
AGE_ENCRYPTION_KEY=AGE-SECRET-KEY-1CHANGE_ME

# Standard Compose image options. The defaults pull the newest stable public
# release. Pin IMAGE_TAG to a Calendar Version for repeatable deployments.
# RIVIAMIGO_IMAGE_REGISTRY=ghcr.io/bballdavis
# IMAGE_TAG=latest
# RIVIAMIGO_ORIGIN_PORT=8080
# RUST_LOG=info

# Reserved object-storage fields. They are accepted for forward compatibility,
# but the current backup workflow does not use them.
# S3_ENDPOINT=https://s3.example.net
# S3_ACCESS_KEY=CHANGE_ME
# S3_SECRET_KEY=CHANGE_ME

# Backup behavior. pg_dump must be available in the API container or host.
# BACKUP_DRIVER=pg_dump
# BACKUP_ARTIFACT_DIR=/backups
# BACKUP_POLL_INTERVAL_SECONDS=60

# Rivian connection and telemetry retention tuning.
# RIVIAN_WS_RECONNECT_INITIAL_SECONDS=10
# RIVIAN_WS_RECONNECT_MAX_SECONDS=900
# RIVIAN_RAW_EVENT_RETENTION_DAYS=7
# RIVIAN_PERSIST_RAW_EVENTS=true
# RIVIAN_PARALLAX_CAPTURE_ENABLED=true
# RIVIAN_SUPPRESS_DUPLICATE_TELEMETRY=true

# API rate limits. Each per-minute value needs its matching burst value.
# RATE_LIMIT_AUTH_PUBLIC_PER_MINUTE=30
# RATE_LIMIT_AUTH_PUBLIC_BURST=10
# RATE_LIMIT_AUTH_METADATA_PER_MINUTE=1200
# RATE_LIMIT_AUTH_METADATA_BURST=120
# RATE_LIMIT_AUTH_READ_PER_MINUTE=900
# RATE_LIMIT_AUTH_READ_BURST=180
# RATE_LIMIT_AUTH_WRITE_PER_MINUTE=240
# RATE_LIMIT_AUTH_WRITE_BURST=60
# RATE_LIMIT_HEAVY_READ_PER_MINUTE=300
# RATE_LIMIT_HEAVY_READ_BURST=90

# Direct API runs only. Supply these through the API process environment.
# Standard Compose defaults to production unless this is explicitly changed.
# RIVIAMIGO_ENV=development
# PORT=3001
# REDIS_URL=redis://localhost:6379
# COOKIE_INSECURE=1

# Local development stack overrides. Export these before `pnpm dev:stack`;
# scripts/dev.mjs selects free ports when they are absent. Do not add them to
# a production .env file.
# DEV_API_PORT=3001
# DEV_WEB_PORT=5173
# DEV_POSTGRES_PORT=5432
# DEV_REDIS_PORT=6379
# DEV_GARAGE_PORT=3900
# DEV_GARAGE_ADMIN_PORT=3903
# DEV_WEB_ORIGINS=http://localhost:5173
# DEV_COMPOSE_PROJECT_NAME=riviamigo
# COMPOSE_PROJECT_NAME=riviamigo

# Frontend local development and contract-test overrides. Put these in the
# repository-root .env.local when Vite needs them.
# VITE_RIVIAMIGO_API_BASE_URL=http://localhost:3001
# VITE_RIVIAMIGO_DEV_API_KEY=rmigo_REPLACE_ME
# VITE_API_URL=http://localhost:3001
# VITE_WS_URL=http://localhost:3001
