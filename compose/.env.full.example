# Riviamigo complete environment reference
#
# Normal production installs need only the three values in .env.example.
# Uncomment optional values only when overriding a documented default. The
# published reference is https://riviamigo.com/docs/reference/environment-variables/

# Standard production installation
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
ALLOWED_ORIGINS=https://riviamigo.example.net
# POSTGRES_USER=riviamigo
# DATABASE_URL=postgresql://riviamigo:password@timescaledb:5432/riviamigo
# REDIS_URL=redis://:password@redis:6379

# Image and Compose behavior
# RIVIAMIGO_IMAGE_REGISTRY=ghcr.io/bballdavis
# IMAGE_TAG=latest
# RIVIAMIGO_ORIGIN_PORT=8080
# RIVIAMIGO_ENV_FILE=../.env

# Optional externally managed application keys. Supply all three or none.
# When omitted, Riviamigo generates and persists them in PostgreSQL.
# JWT_SECRET=-----BEGIN PRIVATE KEY-----...
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----...
# AGE_ENCRYPTION_KEY=AGE-SECRET-KEY-1...

# Application runtime
# RIVIAMIGO_ENV=production
# PORT=3001
# RUST_LOG=info
# COOKIE_INSECURE=1
# VEHICLE_IMAGE_CACHE_DIR=/data/cache/riviamigo/vehicle-images
# BACKUP_DRIVER=pg_dump
# BACKUP_ARTIFACT_DIR=/backups
# BACKUP_POLL_INTERVAL_SECONDS=60

# Reserved object-storage fields. The current recovery worker does not use them.
# S3_ENDPOINT=https://s3.example.net
# S3_ACCESS_KEY=CHANGE_ME
# S3_SECRET_KEY=CHANGE_ME

# Rivian connection and telemetry behavior
# RIVIAN_GRAPHQL_GATEWAY_URL=https://rivian.com/api/gql/gateway/graphql
# RIVIAN_WS_RECONNECT_INITIAL_SECONDS=10
# RIVIAN_WS_RECONNECT_MAX_SECONDS=900
# RIVIAN_RAW_EVENT_RETENTION_DAYS=7
# RIVIAN_PERSIST_RAW_EVENTS=true
# RIVIAN_PARALLAX_CAPTURE_ENABLED=true
# RIVIAN_SUPPRESS_DUPLICATE_TELEMETRY=true

# API rate limits
# RATE_LIMIT_AUTH_PUBLIC_PER_MINUTE=30
# RATE_LIMIT_AUTH_PUBLIC_BURST=10
# RATE_LIMIT_AUTH_METADATA_PER_MINUTE=1200
# RATE_LIMIT_AUTH_METADATA_BURST=120
# RATE_LIMIT_AUTH_READ_PER_MINUTE=900
# RATE_LIMIT_AUTH_READ_BURST=180
# RATE_LIMIT_AUTH_WRITE_PER_MINUTE=240
# RATE_LIMIT_AUTH_WRITE_BURST=60
# RATE_LIMIT_HEAVY_READ_PER_MINUTE=300
# RATE_LIMIT_HEAVY_READ_BURST=90

# Local development stack. These do not change production Compose.
# DEV_API_PORT=3001
# DEV_WEB_PORT=5173
# DEV_POSTGRES_PORT=5432
# DEV_REDIS_PORT=6379
# DEV_GARAGE_PORT=3900
# DEV_GARAGE_ADMIN_PORT=3903
# DEV_WEB_ORIGINS=http://localhost:5173
# DEV_COMPOSE_PROJECT_NAME=riviamigo
# DEV_DATABASE_READY_TIMEOUT_SECONDS=600
# COMPOSE_PROJECT_NAME=riviamigo

# Frontend development and contract tests
# VITE_RIVIAMIGO_API_BASE_URL=http://localhost:3001
# VITE_RIVIAMIGO_DEV_API_KEY=rmigo_REPLACE_ME
# VITE_RIVIAMIGO_RUN_LIVE_CONTRACT=0
# VITE_API_URL=http://localhost:3001
# VITE_WS_URL=http://localhost:3001
