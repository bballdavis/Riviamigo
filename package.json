{
  "name": "riviamigo",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-only",
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
  "engines": {
    "node": ">=24.18 <25",
    "pnpm": ">=11.15 <12"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:stack": "node ./scripts/dev.mjs",
    "build": "turbo build",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "docs:dev": "pnpm --filter @riviamigo/docs start",
    "docs:build": "pnpm --filter @riviamigo/docs build",
    "docs:serve": "pnpm --filter @riviamigo/docs serve",
    "docs:check": "node ./scripts/check-docs.mjs",
    "deps:check": "node ./scripts/check-dependency-policy.mjs && knip --dependencies",
    "deps:catalogs": "node ./scripts/check-dependency-policy.mjs --catalogs-only",
    "verify:fresh-install": "node ./scripts/verify-fresh-install.mjs",
    "verify:backup-restore-s3": "node ./scripts/verify-backup-restore-s3.mjs",
    "verify:restore-compatibility": "node ./tools/restore-lab/run.mjs",
    "verify:migration-integrity": "node ./tools/migration-integrity.mjs",
    "verify:release-image": "node ./scripts/verify-release-image.mjs",
    "dashboards:sync-defaults": "node ./scripts/sync-dashboard-defaults.mjs",
    "storybook": "turbo storybook",
    "clean": "turbo clean && rm -rf node_modules",
    "db:migrate": "node ./scripts/database.mjs migrate",
    "db:reset": "node ./scripts/database.mjs reset",
    "db:rebaseline": "cd apps/api && cargo run --bin rebaseline_db --"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint-react/eslint-plugin": "^5.17.2",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "knip": "^6.27.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5"
  },
  "knip": {
    "ignoreDependencies": [
      "@cmfcmf/docusaurus-search-local",
      "@cmfcmf/docusaurus-plugin-docusaurus-search-local",
      "@riviamigo/config",
      "@riviamigo/ui",
      "prettier"
    ],
    "ignoreBinaries": [
      "sqlx"
    ]
  }
}
