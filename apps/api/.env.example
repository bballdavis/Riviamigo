DATABASE_URL=postgresql://riviamigo:devpassword@localhost:5432/riviamigo
REDIS_URL=redis://localhost:6379

# JWT RSA keypair — optional. If unset, an RSA-2048 keypair is auto-generated
# at first boot and stored in the system_config table for subsequent starts.
# To override: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt_private.pem
#              openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# JWT_SECRET=<contents of jwt_private.pem>
# JWT_PUBLIC_KEY=<contents of jwt_public.pem>

# age X25519 secret key — optional. Auto-generated at first boot if unset.
# To override: age-keygen  (copy the AGE-SECRET-KEY-... line)
# AGE_ENCRYPTION_KEY=AGE-SECRET-KEY-...

PORT=3001
ALLOWED_ORIGINS=http://localhost:3000
S3_ENDPOINT=http://localhost:3900
S3_ACCESS_KEY=GKdeadbeef0000000000000000000000
S3_SECRET_KEY=deadbeef0000000000000000000000000000000000000000000000000000cafe
RUST_LOG=riviamigo_api=debug,tower_http=info
