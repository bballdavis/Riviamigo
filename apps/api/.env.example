# ── Riviamigo API — environment variables ──────────────────────────────────
# The canonical .env.example lives at the repo root.  Copy that file to .env
# in the repo root and the scripts will source it automatically.
#
# The variables below are the minimum needed to run `cargo run` from this
# directory directly (without the root .env).

DATABASE_URL=postgresql://riviamigo:devpassword@localhost:5432/riviamigo
REDIS_URL=redis://localhost:6379

# JWT RSA keypair — optional. If unset, an RSA-2048 keypair is auto-generated
# at first boot and stored in the system_config table for subsequent starts.
# To override: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt_private.pem
#              openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# JWT_SECRET=<contents of jwt_private.pem>
# JWT_PUBLIC_KEY=<contents of jwt_public.pem>

# age X25519 secret key — optional. Auto-generated at first boot if unset.
# To override: age-keygen  (copy the AGE-SECRET-KEY-... line)
# AGE_ENCRYPTION_KEY=AGE-SECRET-KEY-...

PORT=3001
ALLOWED_ORIGINS=http://localhost:3000
COOKIE_INSECURE=1

# API rate limits use per-minute refill values plus a separate burst bucket.
# Uncomment to override the self-hosted defaults from src/config.rs.
# RATE_LIMIT_AUTH_PUBLIC_PER_MINUTE=30
# RATE_LIMIT_AUTH_PUBLIC_BURST=10
# RATE_LIMIT_AUTH_METADATA_PER_MINUTE=1200
# RATE_LIMIT_AUTH_METADATA_BURST=120
# RATE_LIMIT_AUTH_READ_PER_MINUTE=900
# RATE_LIMIT_AUTH_READ_BURST=180
# RATE_LIMIT_AUTH_WRITE_PER_MINUTE=240
# RATE_LIMIT_AUTH_WRITE_BURST=60
# RATE_LIMIT_HEAVY_READ_PER_MINUTE=300
# RATE_LIMIT_HEAVY_READ_BURST=90

# S3 / Garage — only needed if BACKUP_DRIVER=s3.  These are placeholders.
# S3_ENDPOINT=http://localhost:3900
# S3_ACCESS_KEY=CHANGE_ME
# S3_SECRET_KEY=CHANGE_ME

RUST_LOG=riviamigo_api=debug,tower_http=info

# Backup runtime note:
# - BACKUP_DRIVER defaults to pg_dump in the API.
# - If running outside Docker, install PostgreSQL client tools and ensure
#   `pg_dump` is on PATH (`pg_dump --version`).
# - For non-dump testing, set BACKUP_DRIVER=json (manifest-only, no table data).
