# ── Riviamigo web app — environment variables ──────────────────────────────
# Production Compose templates live in compose/.env.example and
# compose/.env.full.example. Vite picks up VITE_* variables from the repo root.
#
# Copy this file to .env.local if you need to override only the frontend vars.
# Never commit real credentials.

# URL of the Riviamigo API (no trailing slash)
VITE_RIVIAMIGO_API_BASE_URL=http://localhost:3001

# API key for local development contract tests (store real key in .env.local)
VITE_RIVIAMIGO_DEV_API_KEY=rmigo_REPLACE_ME
