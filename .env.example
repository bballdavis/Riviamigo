# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://riviamigo:devpassword@localhost:5432/riviamigo

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT & age encryption keys (optional) ──────────────────────────────────────
# Keys are auto-generated on first API boot and stored in the database.
# Leave these unset for auto-generation. To override (e.g., for production):
#
# JWT_SECRET=<RSA private key PEM content>
# JWT_PUBLIC_KEY=<RSA public key PEM content>
# AGE_ENCRYPTION_KEY=AGE-SECRET-KEY-...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Local API contract tests
# Store real keys in .env.local only. The file is gitignored.
VITE_RIVIAMIGO_DEV_API_KEY=rmigo_REPLACE_ME
VITE_RIVIAMIGO_API_BASE_URL=http://localhost:3001

# ── S3 / Garage (object storage) ─────────────────────────────────────────────
S3_ENDPOINT=http://localhost:3900
S3_ACCESS_KEY=GKdeadbeef0000000000000000000000
S3_SECRET_KEY=deadbeef0000000000000000000000000000000000000000000000000000cafe

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=riviamigo_api=debug,tower_http=info
