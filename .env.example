# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://riviamigo:riviamigo@localhost:5432/riviamigo

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT RS256 key paths ────────────────────────────────────────────────────────
# Generate with:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
JWT_PRIVATE_KEY_PATH=./jwt_private.pem
JWT_PUBLIC_KEY_PATH=./jwt_public.pem

# ── age encryption key ─────────────────────────────────────────────────────────
# Generate with:
#   age-keygen -o age_key.txt
# Then paste the public key here and the path to the private key file
AGE_PUBLIC_KEY=age1...
AGE_PRIVATE_KEY_PATH=./age_key.txt

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# In apps/web/.env.local:
# VITE_API_URL=http://localhost:3001

# ── Garage S3 (optional, for object storage) ─────────────────────────────────
# Dev credentials are seeded automatically by infra/garage-entrypoint.sh
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_ACCESS_KEY=GKdeadbeef0000000000000000000000
S3_SECRET_KEY=deadbeef0000000000000000000000000000000000000000000000000000cafe
