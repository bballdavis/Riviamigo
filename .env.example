# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://riviamigo:devpassword@localhost:5432/riviamigo

# ── Redis ─────────────────────────────────────────────────────────────────────
# Temporary connect / OTP state is staged here for a short TTL. Keep Redis on a
# trusted internal network and do not expose it publicly.
REDIS_URL=redis://localhost:6379

# ── JWT & age encryption keys (optional in dev, recommended in production) ───
# In local dev these can be auto-generated on first API boot and stored in the
# database for convenience.
# In production, prefer supplying these from your deployment environment or a
# secret manager so encrypted credential blobs and the active encryption keys
# are not co-resident by default.
#
# JWT_SECRET=<RSA private key PEM content>
# JWT_PUBLIC_KEY=<RSA public key PEM content>
# AGE_ENCRYPTION_KEY=AGE-SECRET-KEY-...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Local API contract tests
# Store real keys in .env.local only. The file is gitignored.
VITE_RIVIAMIGO_DEV_API_KEY=rmigo_REPLACE_ME
VITE_RIVIAMIGO_API_BASE_URL=http://localhost:3001

# ── S3 / Garage (object storage) ─────────────────────────────────────────────
S3_ENDPOINT=http://localhost:3900
S3_ACCESS_KEY=GKdeadbeef0000000000000000000000
S3_SECRET_KEY=deadbeef0000000000000000000000000000000000000000000000000000cafe

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=riviamigo_api=debug,tower_http=info

# ── Security ──────────────────────────────────────────────────────────────────
# Set to any value to allow insecure (non-Secure) cookies in local dev
# NEVER set this in production
COOKIE_INSECURE=1

# Postgres credentials for production (used by docker-compose.prod.yml)
POSTGRES_USER=riviamigo
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Docker image tag for production deploys
IMAGE_TAG=latest
