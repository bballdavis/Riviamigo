# ══════════════════════════════════════════════════════════════════════════════
# Riviamigo — environment variable reference
#
# Copy this file to .env for local development. Never commit real credentials.
# For production, supply values via your deployment environment or secret
# manager rather than a .env file.
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment ───────────────────────────────────────────────────────────────
# Controls runtime behaviour.  Valid values: development | production
# Config::validate() will reject COOKIE_INSECURE when set to "production".
RIVIAMIGO_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://riviamigo:CHANGE_ME@localhost:5432/riviamigo

# ── Redis ─────────────────────────────────────────────────────────────────────
# OTP + refresh-lock state.  Keep on a trusted internal network.
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=CHANGE_ME        # uncomment if your Redis requires auth

# ── JWT & age encryption keys ─────────────────────────────────────────────────
# Development only: keys are auto-generated on first boot and persisted to the
# database if not supplied. Production startup rejects the generated-key path.
# Inject all three values from a secret manager or protected deployment
# environment; never commit them to a Compose env file.
#
# JWT_SECRET=<RSA private key PEM>
# JWT_PUBLIC_KEY=<RSA public key PEM>
# AGE_ENCRYPTION_KEY=AGE-SECRET-KEY-1...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Dev stack local host ports. If a port is already in use, dev.mjs will
# increment until it finds a free one unless overridden here.
DEV_API_PORT=3001
DEV_WEB_PORT=5173
DEV_POSTGRES_PORT=5432
DEV_REDIS_PORT=6379
DEV_GARAGE_PORT=3900
DEV_GARAGE_ADMIN_PORT=3903
DEV_WEB_ORIGINS=http://localhost:5173
DEV_COMPOSE_PROJECT_NAME=riviamigo

# ── Security ──────────────────────────────────────────────────────────────────
# Allow non-Secure cookies in local HTTP dev.
# ⚠  NEVER set this when RIVIAMIGO_ENV=production.  The API will refuse to
#    start if COOKIE_INSECURE is set alongside RIVIAMIGO_ENV=production.
COOKIE_INSECURE=1

# API rate limits use per-minute refill values plus a separate burst bucket.
# These defaults are tuned for self-hosted dashboard browsing, not hostile public traffic.
# RATE_LIMIT_AUTH_PUBLIC_PER_MINUTE=30
# RATE_LIMIT_AUTH_PUBLIC_BURST=10
# RATE_LIMIT_AUTH_METADATA_PER_MINUTE=1200
# RATE_LIMIT_AUTH_METADATA_BURST=120
# RATE_LIMIT_AUTH_READ_PER_MINUTE=900
# RATE_LIMIT_AUTH_READ_BURST=180
# RATE_LIMIT_AUTH_WRITE_PER_MINUTE=240
# RATE_LIMIT_AUTH_WRITE_BURST=60
# RATE_LIMIT_HEAVY_READ_PER_MINUTE=300
# RATE_LIMIT_HEAVY_READ_BURST=90

# ── S3 / Garage (object storage) ─────────────────────────────────────────────
# Required only if the backup driver is "s3".  Leave commented out otherwise.
# S3_ENDPOINT=http://localhost:3900
# S3_ACCESS_KEY=YOUR_GARAGE_ACCESS_KEY
# S3_SECRET_KEY=YOUR_GARAGE_SECRET_KEY

# ── Backup ────────────────────────────────────────────────────────────────────
# BACKUP_DRIVER=pg_dump              # pg_dump (default) or json (manifest-only)
# BACKUP_ARTIFACT_DIR=/tmp/riviamigo-backups
# BACKUP_POLL_INTERVAL_SECONDS=60
# For BACKUP_DRIVER=pg_dump, `pg_dump` must be installed and on PATH in the API runtime.
# Verify with:
#   - Container: docker compose exec api pg_dump --version
#   - Host:      pg_dump --version

# ── Rivian WebSocket reconnect tuning ─────────────────────────────────────────
# RIVIAN_WS_RECONNECT_INITIAL_SECONDS=10
# RIVIAN_WS_RECONNECT_MAX_SECONDS=900

# ── Rivian telemetry retention ────────────────────────────────────────────────
# RIVIAN_RAW_EVENT_RETENTION_DAYS=7      # days to keep raw WebSocket events
# RIVIAN_PERSIST_RAW_EVENTS=true         # set false to drop raw events immediately
# RIVIAN_SUPPRESS_DUPLICATE_TELEMETRY=true

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=riviamigo_api=debug,tower_http=info

# ── Frontend dev (Vite) ───────────────────────────────────────────────────────
# Used for local API contract tests.  Store real keys in .env.local (gitignored).
VITE_RIVIAMIGO_DEV_API_KEY=rmigo_REPLACE_ME
VITE_RIVIAMIGO_API_BASE_URL=http://localhost:3001

# ── Production Docker Compose ─────────────────────────────────────────────────
POSTGRES_USER=riviamigo
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION
IMAGE_TAG=latest
# Optional: change the loopback-only production origin listener.
# RIVIAMIGO_ORIGIN_PORT=8080
